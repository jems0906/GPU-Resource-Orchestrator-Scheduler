# =============================================================
# GPU Resource Orchestrator — Environment Variables
# Copy this file to .env and fill in real values before deploying
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=gpu_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=gpu_orchestrator

# --- Redis ---
# Configured via docker-compose (no external secret needed for local)

# --- Backend ---
SECRET_KEY=change-me-random-64-char-secret
DEFAULT_API_KEY=change-me-api-key

# Set to true only for local development (relaxes auth)
DEBUG=false

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost,http://localhost:80

# --- Cloud Providers (mock by default; set to false to disable) ---
ENABLE_AWS=true
ENABLE_GCP=true
ENABLE_AZURE=true

# AWS regions to include
AWS_REGIONS=us-east-1,us-west-2,eu-west-1

# GCP regions to include
GCP_REGIONS=us-central1,us-east1,europe-west4

# Azure regions to include
AZURE_REGIONS=eastus,westus2,westeurope

# --- Scheduler ---
SCHEDULER_INTERVAL_SECONDS=2.0
SPOT_DISCOUNT_FACTOR=0.30

# Minutes before deadline to emit SLA warning
SLA_WARNING_THRESHOLD_MINUTES=30
